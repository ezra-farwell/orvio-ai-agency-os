# ---------- App (browser) ----------
# Set once the Supabase project exists (Project Settings → API).
# The app runs on mock data until both are present, then switches to live.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------- Edge Function secrets (NOT in the browser) ----------
# Set with: supabase secrets set NAME=value
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY / SUPABASE_ANON_KEY are injected automatically.
#
# APP_URL=https://app.orvio.com        # where OAuth bounces back to
#
# Meta (developers.facebook.com → create an app, Marketing API):
# META_APP_ID=...
# META_APP_SECRET=...
#
# Google (console.cloud.google.com → OAuth client; Google Ads API):
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_ADS_DEVELOPER_TOKEN=...       # required to pull Google Ads metrics
