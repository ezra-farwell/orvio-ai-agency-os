# Public Supabase browser configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Supabase server configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-public-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Orvio AI server-only configuration
ORVIO_AI_PROVIDER=ollama
ORVIO_AI_BASE_URL=http://localhost:11434/v1
ORVIO_AI_MODEL=llama3.1:8b
ORVIO_AI_API_KEY=
ORVIO_AI_TIMEOUT_MS=120000

# Future server-side integrations
APIFY_TOKEN=your-apify-token
APIFY_ACTOR_ID=your-apify-actor-id
HF_CREDENTIALS=your-higgsfield-credentials
