VITE_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-public-key
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-public-key

# ---------------------------------------------------------------------------
# Orvio AI — server-side config (never exposed to the browser)
#
# LOCAL DEV  → points directly at your Ollama instance, no auth header needed.
# PRODUCTION → points at the Cloudflare Tunnel URL in front of the auth proxy.
#              See orvio-ai/proxy/TUNNEL.md for proxy + tunnel setup.
# ---------------------------------------------------------------------------

# Which provider implementation to use. Only "ollama" is supported today.
ORVIO_AI_PROVIDER=ollama

# --- LOCAL DEV (default — works out of the box if Ollama is running) ---
ORVIO_AI_BASE_URL=http://localhost:11434/v1
# Ollama ignores this value; set it to anything non-empty so the zod schema passes.
ORVIO_AI_API_KEY=ollama

# --- PRODUCTION (set these in Vercel → Settings → Environment Variables) ---
# ORVIO_AI_BASE_URL=https://ai.yourdomain.com/v1
#   └─ The stable HTTPS tunnel URL + /v1 suffix.
#      Must point to the auth proxy (orvio-ai/proxy/), NOT directly at Ollama.
#
# ORVIO_AI_API_KEY=<long-random-secret>
#   └─ Must match ORVIO_PROXY_SECRET in orvio-ai/proxy/.env on your homelab PC.
#      Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#      This value is sent as the Bearer token; the proxy validates it before forwarding.

# Model — must match the model pulled in Ollama. No change needed for Llama 3.1 8B.
ORVIO_AI_MODEL=llama3.1:8b

# Request timeout in milliseconds (covers the full round-trip: queue wait + inference).
# 120s is tight for a 6GB VRAM card on an 8B model but reasonable for beta scale.
# Must also be set on the homelab proxy as ORVIO_AI_TIMEOUT_MS (see orvio-ai/proxy/.env.example).
ORVIO_AI_TIMEOUT_MS=120000

# ---------------------------------------------------------------------------
# Server-side integrations (fill in as you wire each one up)
# ---------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
APIFY_TOKEN=your-apify-token
APIFY_ACTOR_ID=your-apify-actor-id
HF_CREDENTIALS=your-higgsfield-or-hf-credentials
