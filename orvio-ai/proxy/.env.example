# Orvio AI proxy config — copy to .env and fill in.
# This file lives only on your homelab PC, never in the repo or on Vercel.

# Shared secret — must match ORVIO_AI_API_KEY in your Vercel environment variables.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ORVIO_PROXY_SECRET=replace-with-a-long-random-string

# Local Ollama URL (default is fine unless you changed the Ollama port)
OLLAMA_URL=http://localhost:11434

# Port the proxy listens on (Cloudflare Tunnel points here)
PROXY_PORT=3001

# How long a queued request waits before giving up (should match Vercel's ORVIO_AI_TIMEOUT_MS)
ORVIO_AI_TIMEOUT_MS=120000

# Max requests that may wait in queue behind the one in-flight.
# At concurrency=1, more than 3 queued means the user should get a fast "busy" reply
# rather than waiting 6+ minutes for their turn.
ORVIO_AI_MAX_QUEUE=3
