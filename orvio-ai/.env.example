# Orvio AI worker — runs on YOUR PC. Copy to .env and fill in.
# The service key is powerful (bypasses RLS) — it stays on your machine only,
# never in the repo or the browser. orvio-ai/.env is gitignored.
SUPABASE_URL=https://buvdoplasztgjuhkecze.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # Supabase → Project Settings → API → service_role
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b                       # after the 3090: qwen2.5:14b or 32b
